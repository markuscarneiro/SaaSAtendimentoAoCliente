# =============================================================
# .env.prod.example — variáveis para docker-compose.prod.yml
# Copie para .env (ou injete via secrets do seu provedor) antes de rodar:
#   docker compose -f docker-compose.prod.yml up --build -d
#
# Todas as variáveis abaixo são OBRIGATÓRIAS em produção — o Compose falha
# imediatamente se alguma estiver ausente (sem default inseguro).
# NUNCA commit .env com valores reais. Gere segredos com, por exemplo:
#   openssl rand -base64 48
# =============================================================

# ---- API (porta exposta no host) ----------------------------
API_PORT=3000

# ---- PostgreSQL --------------------------------------------
POSTGRES_DB=saas_atendimento
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_RANDOM_PASSWORD
DATABASE_URL=postgresql://CHANGE_ME:CHANGE_ME_USE_A_STRONG_RANDOM_PASSWORD@postgres:5432/saas_atendimento

# ---- Redis ----------------------------------------------------
REDIS_URL=redis://redis:6379

# ---- JWT (auth-spec §3.2.1) ---------------------------------
# Mínimo 32 caracteres, aleatório. Nunca reutilize o valor de exemplo.
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=24h

# ---- URLs / CORS (architecture.md §6, ADR-0005) -------------
# URL pública do dashboard web (usada pelo backend para CORS)
APP_BASE_URL=https://CHANGE_ME.example.com
# URL pública da API (usada pelo frontend para chamadas HTTP, embutida no build)
API_BASE_URL=https://CHANGE_ME-api.example.com

# ---- Porta exposta do web no host ---------------------------
WEB_PORT=5173

# ---- Rate limit de login (security-spec §8) -----------------
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
