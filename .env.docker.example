# =============================================================
# .env.docker.example — variáveis para execução via Docker Compose
# Copie para .env e ajuste antes de rodar `docker compose up --build`.
# Diferença principal: DATABASE_URL e REDIS_URL usam nomes de serviço
# Docker (postgres, redis) em vez de localhost.
# NUNCA commit .env com valores reais.
# =============================================================

# ---- Ambiente ------------------------------------------------
NODE_ENV=development

# ---- API (porta exposta no host) ----------------------------
PORT=3000

# ---- PostgreSQL (Docker: nome do serviço "postgres") --------
POSTGRES_DB=saas_atendimento
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/saas_atendimento

# ---- Redis (Docker: nome do serviço "redis") ----------------
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---- JWT (auth-spec §3.2.1) ---------------------------------
# Nunca commite o segredo real. Use string longa e aleatória em produção.
JWT_SECRET=change-me-use-at-least-32-random-characters
JWT_EXPIRES_IN=24h

# ---- URLs / CORS (architecture.md §6, ADR-0005) -------------
# URL base do dashboard web (usada pelo backend para CORS)
APP_BASE_URL=http://localhost:5173
# URL base da API (usada pelo frontend para chamadas HTTP)
API_BASE_URL=http://localhost:3000

# ---- Porta exposta do web no host ---------------------------
WEB_PORT=5173

# ---- Rate limit de login (security-spec §8) -----------------
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
